#!/usr/bin/env bash
# Simple runner for build/<lang>/runner
# Language comes from LC_LANG (env). Override with -l/--lang.
# -c/--category <cat>   Run a category
# -a/--all              Run all (LC_PROB_NUM=all)
# -l (no arg) or -L     List categories & problems
# -h/--help or no args  Usage
# -s, --submit <id>     Extract and submit online (lang from -l or $LC_LANG)
set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
Usage:
  ./run [options]

Options:
  -l, --lang [cpp|go|java|python]  With an argument: set language (default from $LC_LANG via .env, else cpp)
                       Without an argument: list categories & problems
  -t [cpp|go|java|python]     Set default language in .env (writes LC_LANG) and exit
  -p, --problem [id]   Run a single problem id (if omitted, uses $LC_PROB_NUM or $LC_PROB_NO)
  -e, --example [num]  Run STL example (1=vector, 2=list, ..., 10=priority_queue)
  -c, --category [cat] Run the given category (if omitted, uses $LC_CATEGORY)
  -a, --all            Run all problems (sets LC_PROB_NUM=all)
  -L                   List categories & problems (same as bare -l)
  -h, --help           Show this help
  -s, --submit <id>    Extract and submit via vsc-leetcode-cli (lang from -l or $LC_LANG)

Notes:
  • Runs prebuilt binaries: build/<lang>/runner
  • If the runner is missing, this script auto-builds it via: make -C src/<lang> all
  • Exports LC_PROB_NUM / LC_CATEGORY for the runners
  • Errors out if a single problem is requested but not implemented in the selected language

Examples:
  ./run -p 94
  ./run -e 1       # Run STL example 01_vector.cpp
  ./run -l go -p 94
  ./run -t go      # persist default language
  ./run -c sliding_window
  ./run -a
  ./run -l        # list
  ./run -L        # list
  ./run -s 9 -l cpp   # extract + submit problem 9 (C++)
EOF
}

die() { echo "ERROR: $*" >&2; exit 2; }

# --- Load environment from .env
if [[ -f "$ROOT/.env" ]]; then
  # shellcheck disable=SC1091
  source "$ROOT/.env"
fi

# --- Discover default language safely ---
DEFAULT_LANG="${LC_LANG:-cpp}"

# --- Helpers ---
runner_path() { echo "$ROOT/build/$1/runner"; }

ensure_runner() {
  local lang="$1" bin; bin="$(runner_path "$lang")"
  echo "Checking/Building runner for $lang..."
  make -C "$ROOT/src/$lang" all || die "Build failed for language '$lang'"
  [[ -x "$bin" ]] || die "Runner still missing after build: $bin"
}

list_from_testcases() {
  python3 - <<'PY'
import json, sys
from pathlib import Path

p = Path("testcases.json")
if not p.exists():
    print("ERROR: testcases.json not found", file=sys.stderr); sys.exit(2)

data = json.loads(p.read_text(encoding="utf-8"))
probs = data.get("problems", data)

def it():
    if isinstance(probs, dict):
        for k, v in probs.items(): yield str(k), v
    else:
        for v in probs: yield str(v.get("id","")), v

rows, cats = [], set()
for k, v in it():
    desc = (v.get("description") or "").strip()
    cat  = (v.get("category") or "misc").strip()
    cats.add(cat)
    try: key = int(k)
    except: key = 10**9
    rows.append((key, k, cat, desc))

rows.sort()
print("Categories:")
for c in sorted(cats):
    print("  -", c)
print("\nProblems:")
print("  ID   Category             Title")
for _, k, c, d in rows:
    print(f"  {k:<4} {c:<20} {d}")
PY
}

problem_exists_in_tests() {
  local id="$1"
  python3 - "$id" <<'PY'
import json, sys
from pathlib import Path
pid = sys.argv[1]
d = json.loads(Path("testcases.json").read_text(encoding="utf-8"))
p = d.get("problems", d)
ok = (pid in p) if isinstance(p, dict) else any(str(x.get("id"))==pid for x in p)
sys.exit(0 if ok else 1)
PY
}

has_impl() {
  local lang="$1" id="$2"
  shopt -s nullglob
  local m=()
  case "$lang" in
    cpp)
      m=( \
        "$ROOT/src/cpp/${id}."*".cpp" "$ROOT/src/cpp/${id}.cpp" \
        "$ROOT/src/cpp/hash/${id}."*".cpp" "$ROOT/src/cpp/list/${id}."*".cpp" \
        "$ROOT/src/cpp/sliding_window/${id}."*".cpp" "$ROOT/src/cpp/misc/${id}."*".cpp" \
        "$ROOT/src/cpp/two_pointer/${id}."*".cpp" "$ROOT/src/cpp/tree/${id}."*".cpp"
      )
      ;;
    go)
      m=( \
        "$ROOT/src/go/${id}."*".go" "$ROOT/src/go/${id}.go" \
        "$ROOT/src/go/hash/${id}."*".go" "$ROOT/src/go/list/${id}."*".go" \
        "$ROOT/src/go/sliding_window/${id}."*".go" "$ROOT/src/go/misc/${id}."*".go" \
        "$ROOT/src/go/two_pointer/${id}."*".go" "$ROOT/src/go/tree/${id}."*".go"
      )
      ;;
    java)
      m=( \
        "$ROOT/src/java/${id}."*".java" "$ROOT/src/java/${id}.java" \
        "$ROOT/src/java/hash/${id}."*".java" "$ROOT/src/java/list/${id}."*".java" \
        "$ROOT/src/java/sliding_window/${id}."*".java" "$ROOT/src/java/misc/${id}."*".java" \
        "$ROOT/src/java/two_pointer/${id}."*".java" "$ROOT/src/java/tree/${id}."*".java" \
        "$ROOT/src/java/stack/${id}."*".java" \
        "$ROOT/src/java/binary_search/${id}."*".java"
      )
      ;;
    python)
      m=( \
        "$ROOT/src/python/${id}."*".py" "$ROOT/src/python/${id}.py" \
        "$ROOT/src/python/hash/${id}."*".py" "$ROOT/src/python/list/${id}."*".py" \
        "$ROOT/src/python/sliding_window/${id}."*".py" "$ROOT/src/python/misc/${id}."*".py" \
        "$ROOT/src/python/two_pointer/${id}."*".py" "$ROOT/src/python/tree/${id}."*".py" \
        "$ROOT/src/python/stack/${id}."*".py" "$ROOT/src/python/prefix_sum/${id}."*".py" \
        "$ROOT/src/python/graphs/${id}."*".py" "$ROOT/src/python/dp/${id}."*".py" \
        "$ROOT/src/python/binary_search/${id}."*".py" \
      )
      ;;
    *)   shopt -u nullglob; return 1;;
  esac
  shopt -u nullglob
  [[ ${#m[@]} -gt 0 ]]
}

print_lang() {
  case "$1" in
    cpp) echo "Language set to: C++" ;;
    go)  echo "Language set to: Go"  ;;
    java) echo "Language set to: Java" ;;
    python) echo "Language set to: Python" ;;
    *)   echo "Language set to: $1"  ;;
  esac
}

# --- Parse args ---
LANG="$DEFAULT_LANG"
PROB=""
CATEGORY=""
RUN_ALL=0
LIST_ONLY=0
SUBMIT_ID=""
EXAMPLE_NUM=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -t)
      # Set default language by updating $ROOT/.env (LC_LANG)
      if [[ $# -ge 2 && "$2" =~ ^(cpp|go|java|python)$ ]]; then
        TARGET_LANG="$2"
        # Create or update .env with LC_LANG entry
        if [[ -f "$ROOT/.env" ]]; then
          # if LC_LANG exists, replace it; else append
          if grep -q '^LC_LANG=' "$ROOT/.env"; then
            sed -i -E 's/^LC_LANG=.*/LC_LANG='"$TARGET_LANG"'/' "$ROOT/.env"
          else
            echo "LC_LANG=$TARGET_LANG" >> "$ROOT/.env"
          fi
        else
          echo "LC_LANG=$TARGET_LANG" > "$ROOT/.env"
        fi
        echo "Default language set to '$TARGET_LANG' in .env (LC_LANG)"
        exit 0
      else
        die "-t requires one of: cpp|go"
      fi
      ;;
    -l|--lang)
      # If next token looks like a valid lang, consume it; else treat bare -l as "list"
      if [[ $# -ge 2 && "$2" =~ ^(cpp|go|java|python)$ ]]; then
        LANG="$2"; shift 2
      else
        LIST_ONLY=1; shift
      fi
      ;;
    -L)
      LIST_ONLY=1; shift ;;
    -e|--example)
      if [[ $# -ge 2 && ! "$2" =~ ^- ]]; then
        EXAMPLE_NUM="$2"; shift 2
      else
        die "--example requires a number (1-10)"
      fi ;;
    -p|--problem)
      if [[ $# -ge 2 && ! "$2" =~ ^- ]]; then
        PROB="$2"; shift 2
      else
        PROB="${LC_PROB_NUM:-${LC_PROB_NO:-}}"
        [[ -n "$PROB" ]] || die "--problem requires an id (or set $LC_PROB_NUM)"
        shift 1
      fi ;;
    -c|--category)
      if [[ $# -ge 2 && ! "$2" =~ ^- ]]; then
        CATEGORY="$2"; shift 2
      else
        CATEGORY="${LC_CATEGORY:-}"
        [[ -n "$CATEGORY" ]] || die "--category requires a value (or set $LC_CATEGORY)"
        shift 1
      fi;;
    -a|--all)
      RUN_ALL=1; shift ;;
    -h|--help)
      usage; exit 0 ;;
    -s|--submit)
      [[ $# -ge 2 ]] || die "--submit requires an id"
      SUBMIT_ID="$2"; shift 2 ;;
    -*)
      die "Unknown option: $1" ;;
    *)
      die "Unknown option or unexpected argument: $1" ;;
  esac
done

# No options/args => print usage
if [[ -z "$PROB" && -z "$CATEGORY" && $RUN_ALL -eq 0 && $LIST_ONLY -eq 0 && -z "$SUBMIT_ID" && -z "$EXAMPLE_NUM" ]]; then
  usage; exit 0
fi

# Example runner mode
if [[ -n "$EXAMPLE_NUM" ]]; then
  # Format number with leading zero (e.g. 1 -> 01)
  PREFIX=$(printf "%02d" "$EXAMPLE_NUM")
  shopt -s nullglob
  FILES=("$ROOT/src/cpp/stl/${PREFIX}_"*.cpp)
  shopt -u nullglob
  
  if [[ ${#FILES[@]} -eq 0 ]]; then
    die "STL example ${EXAMPLE_NUM} not found in src/cpp/stl/"
  fi
  
  TARGET_FILE="${FILES[0]}"
  OUT_BIN="$ROOT/build/cpp/example"
  echo "Compiling ${TARGET_FILE}..."
  g++ -O2 -std=c++20 "$TARGET_FILE" -o "$OUT_BIN" || die "Compilation failed for example ${EXAMPLE_NUM}"
  
  echo "Running STL Example ${EXAMPLE_NUM}: $(basename "$TARGET_FILE")"
  echo "----------------------------------------"
  exec "$OUT_BIN"
fi

# Listing mode doesn't require building
if [[ $LIST_ONLY -eq 1 ]]; then
  list_from_testcases; exit 0
fi

# Submit path: extract then submit online; no runner build needed
if [[ -n "$SUBMIT_ID" ]]; then
  # Preflight checks
  command -v python3 >/dev/null 2>&1 || die "python3 not found; required for submit"
  [[ -f "$ROOT/scripts/submit_lc.py" ]] || die "scripts/submit_lc.py not found"
  if ! command -v leetcode >/dev/null 2>&1; then
    cat >&2 <<'EOT'
ERROR: `leetcode` CLI not found. Please install and login with vsc-leetcode-cli:
  npm uninstall -g leetcode-cli
  npm install -g vsc-leetcode-cli
  leetcode user login
EOT
    exit 2
  fi
  # Choose language: explicit -l overrides, else LC_LANG, default cpp
  LANG_FOR_SUBMIT="${LANG:-${LC_LANG:-cpp}}"
  echo "Submitting problem $SUBMIT_ID for language '$LANG_FOR_SUBMIT'..."
  exec python3 "$ROOT/scripts/submit_lc.py" --id "$SUBMIT_ID" --lang "$LANG_FOR_SUBMIT" --src-root "$ROOT/src" --build-root "$ROOT/build"
fi
case "$LANG" in cpp|go|java|python) : ;; *) die "Unsupported language: $LANG (use cpp|go|java|python)";; esac
print_lang "$LANG"

if [[ "$LANG" == "cpp" ]]; then
  if [[ -n "$PROB" ]]; then
    problem_exists_in_tests "$PROB" || die "Problem $PROB not found in testcases.json"
    has_impl "cpp" "$PROB" || die "Problem $PROB is not implemented for language 'cpp'"
    
    SRC_FILE=""
    for d in backtracking binary_search bit_manipulation concurrency dp graphs greedy hash heap intervals list math misc prefix_sum sliding_window stack tree trie two_pointer; do
      shopt -s nullglob
      MATCHES=("$ROOT/src/cpp/$d/${PROB}."*.cpp)
      shopt -u nullglob
      if [[ ${#MATCHES[@]} -gt 0 ]]; then
        SRC_FILE="${MATCHES[0]}"
        break
      fi
    done
    if [[ -z "$SRC_FILE" ]]; then
      die "Problem $PROB C++ source file not found under src/cpp/"
    fi
    
    REL_SRC="${SRC_FILE#$ROOT/src/cpp/}"
    P_VAL="${REL_SRC%.cpp}"
    
    echo "Building standalone C++ binary for problem $PROB..."
    make -C "$ROOT/src/cpp" "build-one" "P=$P_VAL" || die "Build failed for C++ problem $PROB"
    
    BIN="$ROOT/build/cpp/$P_VAL"
    echo "Running standalone binary: $BIN"
    exec "$BIN"
  elif [[ $RUN_ALL -eq 1 ]]; then
    echo "Building all C++ standalone binaries..."
    make -C "$ROOT/src/cpp" build-all || die "Build all failed"
    echo "Running all C++ solutions:"
    SUCCESS=0
    TOTAL=0
    FAILED_PROBS=()
    
    shopt -s nullglob
    for d in backtracking binary_search bit_manipulation concurrency dp graphs greedy hash heap intervals list math misc prefix_sum sliding_window stack tree trie two_pointer; do
      for bin in "$ROOT/build/cpp/$d/"*; do
        if [[ -f "$bin" && -x "$bin" && ! "$bin" =~ \.o$ ]]; then
          TOTAL=$((TOTAL+1))
          PROB_NAME=$(basename "$bin")
          echo -n "Running $d/$PROB_NAME... "
          if "$bin" >/dev/null 2>&1; then
            echo "PASS"
            SUCCESS=$((SUCCESS+1))
          else
            echo "FAIL"
            FAILED_PROBS+=("$d/$PROB_NAME")
          fi
        fi
      done
    done
    shopt -u nullglob
    
    echo "----------------------------------------"
    echo "Result: $SUCCESS/$TOTAL passed"
    if [[ ${#FAILED_PROBS[@]} -gt 0 ]]; then
      echo "Failed problems:"
      for p in "${FAILED_PROBS[@]}"; do
        echo "  - $p"
      done
      exit 1
    fi
    exit 0
  elif [[ -n "$CATEGORY" ]]; then
    echo "Building C++ standalone binaries for category '$CATEGORY'..."
    shopt -s nullglob
    SRCS=("$ROOT/src/cpp/$CATEGORY/"*.cpp)
    shopt -u nullglob
    if [[ ${#SRCS[@]} -eq 0 ]]; then
      die "No C++ problems found in category '$CATEGORY'"
    fi
    
    for src in "${SRCS[@]}"; do
      REL_SRC="${src#$ROOT/src/cpp/}"
      P_VAL="${REL_SRC%.cpp}"
      make -C "$ROOT/src/cpp" "build-one" "P=$P_VAL" || die "Build failed for $P_VAL"
    done
    
    echo "Running C++ solutions in category '$CATEGORY':"
    SUCCESS=0
    TOTAL=0
    FAILED_PROBS=()
    shopt -s nullglob
    for bin in "$ROOT/build/cpp/$CATEGORY/"*; do
      if [[ -f "$bin" && -x "$bin" && ! "$bin" =~ \.o$ ]]; then
        TOTAL=$((TOTAL+1))
        PROB_NAME=$(basename "$bin")
        echo -n "Running $PROB_NAME... "
        if "$bin" >/dev/null 2>&1; then
          echo "PASS"
          SUCCESS=$((SUCCESS+1))
        else
          echo "FAIL"
          FAILED_PROBS+=("$PROB_NAME")
        fi
      fi
    done
    shopt -u nullglob
    
    echo "----------------------------------------"
    echo "Result: $SUCCESS/$TOTAL passed"
    if [[ ${#FAILED_PROBS[@]} -gt 0 ]]; then
      echo "Failed problems:"
      for p in "${FAILED_PROBS[@]}"; do
        echo "  - $p"
      done
      exit 1
    fi
    exit 0
  fi
else
  # Non-C++ language behavior
  ensure_runner "$LANG"
  BIN="$(runner_path "$LANG")"

  # Prepare env for runner: set only what's requested, keep existing defaults from .env
  if [[ -n "$CATEGORY" ]]; then
    export LC_CATEGORY="$CATEGORY"
    unset LC_PROB_NUM || true
    echo "Mode: category='$LC_CATEGORY'"
    echo "→ $BIN"
    exec "$BIN"
  elif [[ $RUN_ALL -eq 1 ]]; then
    export LC_PROB_NUM="all"
    unset LC_CATEGORY || true
    echo "Mode: run all (LC_PROB_NUM=$LC_PROB_NUM)"
    echo "→ $BIN"
    exec "$BIN"
  elif [[ -n "$PROB" ]]; then
    problem_exists_in_tests "$PROB" || die "Problem $PROB not found in testcases.json"
    has_impl "$LANG" "$PROB" || die "Problem $PROB is not implemented for language '$LANG'"
    export LC_PROB_NUM="$PROB"
    unset LC_CATEGORY || true
    echo "Mode: single problem $LC_PROB_NUM"
    echo "→ $BIN"
    exec "$BIN"
  fi
fi
