{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-java",
            "type": "shell",
            "command": "make",
            "args": ["-C", "${workspaceFolder}/src/java", "all"],
            "group": { "kind": "build" },
            "problemMatcher": []
        },
        {
            "label": "build-cpp-dbg",
            "type": "shell",
            "command": "python3",
            "args": ["${workspaceFolder}/scripts/build_active.py", "--id", "${input:lcProbNum}"],
            "group": { "kind": "build" },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "build-active-cpp-standalone",
            "type": "shell",
            "command": "python3",
            "args": [
                "${workspaceFolder}/scripts/build_active.py",
                "${file}"
            ],
            "group": { "kind": "build" },
            "problemMatcher": ["$gcc"]
        }
    ]
}